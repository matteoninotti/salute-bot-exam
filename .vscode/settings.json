{
  // Point VS Code + Pylance at the project venv so imports (bs4, playwright,
  // cryptography, boto3) resolve. Rebuild with:
  //   python3.14 -m venv .venv && .venv/bin/pip install -r requirements.txt
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests"],

  // recon/*.html + recon/*.xhtml are captured ground-truth fixtures the parser
  // tests are anchored to (byte-for-byte) — never auto-reformat them. The only
  // HTML/XHTML files in this project are those two fixtures, so disabling
  // format-on-save for the HTML language mode workspace-wide is safe.
  "files.associations": {
    "*.xhtml": "html"
  },
  "[html]": {
    "editor.formatOnSave": false
  }
}
